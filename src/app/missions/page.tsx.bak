"use client";

import { motion } from "framer-motion";
import {
  Rocket,
  Globe,
  Target,
  Clock,
  Users,
  CheckCircle2,
  Circle,
  Loader2,
  ArrowUpRight,
} from "lucide-react";

interface Mission {
  id: string;
  name: string;
  designation: string;
  description: string;
  status: "active" | "planning" | "completed" | "scheduled";
  vehicle: string;
  destination: string;
  launchSite: string;
  agents: number;
  progress: number;
  date: string;
  objectives: string[];
}

const missions: Mission[] = [
  {
    id: "1",
    name: "Integrated Flight Test 8",
    designation: "IFT-8",
    description:
      "Full Starship stack test flight with booster catch attempt and orbital insertion of the Ship. Heat shield validation and controlled ocean splashdown.",
    status: "active",
    vehicle: "Starship + Super Heavy",
    destination: "Low Earth Orbit",
    launchSite: "Starbase, TX",
    agents: 7,
    progress: 72,
    date: "Feb 13, 2026",
    objectives: [
      "Full-duration Super Heavy burn",
      "Hot staging separation",
      "Booster return & tower catch",
      "Ship orbital insertion (150x170km)",
      "Reentry heat shield validation",
      "Controlled Indian Ocean splashdown",
    ],
  },
  {
    id: "2",
    name: "Mars Cargo Precursor",
    designation: "MCP-1",
    description:
      "Unmanned Starship cargo mission to Mars carrying habitat modules, ISRU equipment, and power systems for future crew landing site.",
    status: "planning",
    vehicle: "Starship HLS Variant",
    destination: "Mars — Arcadia Planitia",
    launchSite: "Starbase, TX",
    agents: 5,
    progress: 18,
    date: "Jul 2026 (Window)",
    objectives: [
      "Trans-Mars injection",
      "6-month cruise phase",
      "Mars aerocapture & EDL",
      "Cargo module deployment",
      "ISRU propellant production test",
      "Surface power generation",
    ],
  },
  {
    id: "3",
    name: "Starlink V3 Shell Deployment",
    designation: "SL-V3-01",
    description:
      "First operational deployment of Starlink V3 satellites with direct-to-cell capability and laser inter-satellite links.",
    status: "scheduled",
    vehicle: "Starship",
    destination: "550km LEO",
    launchSite: "Starbase, TX",
    agents: 3,
    progress: 45,
    date: "Mar 2026",
    objectives: [
      "Deploy 120 V3 satellites",
      "Verify laser ISL connectivity",
      "Direct-to-cell band activation",
      "Constellation mesh networking",
      "De-orbit test of 2 demo units",
    ],
  },
  {
    id: "4",
    name: "Crew Dragon — ISS Rotation",
    designation: "Crew-14",
    description:
      "Routine crew rotation mission to the International Space Station, carrying 4 astronauts for a 6-month expedition.",
    status: "scheduled",
    vehicle: "Falcon 9 + Crew Dragon",
    destination: "ISS (408km LEO)",
    launchSite: "LC-39A, KSC",
    agents: 2,
    progress: 60,
    date: "Apr 2026",
    objectives: [
      "Crew launch & ascent",
      "Autonomous docking to ISS",
      "Crew handover",
      "6-month expedition",
      "Undocking & reentry",
      "Ocean splashdown recovery",
    ],
  },
  {
    id: "5",
    name: "Artemis IV — Lunar Lander",
    designation: "HLS-2",
    description:
      "SpaceX Starship Human Landing System delivering astronauts to the lunar south pole as part of NASA's Artemis program.",
    status: "planning",
    vehicle: "Starship HLS",
    destination: "Lunar South Pole",
    launchSite: "Starbase, TX",
    agents: 6,
    progress: 12,
    date: "2027",
    objectives: [
      "On-orbit propellant transfer",
      "Trans-lunar injection",
      "Lunar orbit insertion",
      "Powered descent to south pole",
      "Surface EVA operations",
      "Ascent & crew transfer",
    ],
  },
];

const statusConfig = {
  active: {
    label: "ACTIVE",
    color: "text-spacex-success",
    bg: "bg-spacex-success/10",
    border: "border-spacex-success/30",
    dot: "bg-spacex-success animate-pulse",
    icon: Loader2,
  },
  planning: {
    label: "PLANNING",
    color: "text-spacex-accent",
    bg: "bg-spacex-accent/10",
    border: "border-spacex-accent/30",
    dot: "bg-spacex-accent",
    icon: Circle,
  },
  scheduled: {
    label: "SCHEDULED",
    color: "text-spacex-warning",
    bg: "bg-spacex-warning/10",
    border: "border-spacex-warning/30",
    dot: "bg-spacex-warning",
    icon: Clock,
  },
  completed: {
    label: "COMPLETED",
    color: "text-spacex-muted",
    bg: "bg-spacex-muted/10",
    border: "border-spacex-muted/30",
    dot: "bg-spacex-muted",
    icon: CheckCircle2,
  },
};

export default function MissionsPage() {
  return (
    <div className="p-4 lg:p-6 space-y-6">
      {/* Header */}
      <div className="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
          <h1 className="font-display text-lg sm:text-xl font-bold text-white">ACTIVE MISSIONS</h1>
          <p className="text-xs sm:text-sm text-spacex-muted mt-1">
            Current & upcoming SpaceX missions with AI agent collaboration
          </p>
        </div>
        <button className="flex items-center gap-2 px-3 sm:px-4 py-2 sm:py-2.5 rounded-lg bg-spacex-thrust/10 border border-spacex-thrust/20 text-xs sm:text-sm text-spacex-thrust hover:bg-spacex-thrust/20 transition-all font-mono w-fit">
          <Target className="w-4 h-4" />
          NEW MISSION
        </button>
      </div>

      {/* Mission cards */}
      <div className="space-y-4">
        {missions.map((mission, i) => {
          const config = statusConfig[mission.status];
          return (
            <motion.div
              key={mission.id}
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              transition={{ delay: i * 0.08 }}
              className="glass-panel p-5 hover:border-spacex-accent/20 transition-all group cursor-pointer hud-corners"
            >
              <div className="flex flex-col lg:flex-row gap-5">
                {/* Left section */}
                <div className="flex-1 min-w-0">
                  {/* Header row */}
                  <div className="flex items-start gap-4 mb-3">
                    <div className="w-12 h-12 rounded-xl bg-spacex-accent/10 border border-spacex-accent/20 flex items-center justify-center shrink-0">
                      <Rocket className="w-6 h-6 text-spacex-accent" />
                    </div>
                    <div className="flex-1">
                      <div className="flex items-center gap-3 flex-wrap">
                        <h3 className="text-base font-semibold text-white">{mission.name}</h3>
                        <span className="text-xs font-mono text-spacex-accent bg-spacex-accent/10 px-2 py-0.5 rounded">
                          {mission.designation}
                        </span>
                        <span className={`text-[10px] font-mono px-2 py-0.5 rounded ${config.bg} ${config.color} flex items-center gap-1`}>
                          <div className={`w-1.5 h-1.5 rounded-full ${config.dot}`} />
                          {config.label}
                        </span>
                      </div>
                      <p className="text-xs text-spacex-text/60 mt-1 line-clamp-2">{mission.description}</p>
                    </div>
                  </div>

                  {/* Meta row */}
                  <div className="flex flex-wrap items-center gap-3 md:gap-4 text-[10px] md:text-[11px] font-mono text-spacex-muted ml-0 md:ml-16">
                    <span className="flex items-center gap-1.5">
                      <Rocket className="w-3 h-3 text-spacex-accent/60" />
                      {mission.vehicle}
                    </span>
                    <span className="flex items-center gap-1.5">
                      <Globe className="w-3 h-3 text-spacex-accent/60" />
                      {mission.destination}
                    </span>
                    <span className="flex items-center gap-1.5">
                      <Target className="w-3 h-3 text-spacex-accent/60" />
                      {mission.launchSite}
                    </span>
                    <span className="flex items-center gap-1.5">
                      <Clock className="w-3 h-3 text-spacex-accent/60" />
                      {mission.date}
                    </span>
                    <span className="flex items-center gap-1.5">
                      <Users className="w-3 h-3 text-spacex-accent/60" />
                      {mission.agents} agents
                    </span>
                  </div>
                </div>

                {/* Right section - Progress + Objectives */}
                <div className="lg:w-72 shrink-0 space-y-3">
                  {/* Progress */}
                  <div>
                    <div className="flex items-center justify-between mb-1">
                      <span className="text-[10px] font-mono text-spacex-muted">PROGRESS</span>
                      <span className="text-xs font-mono font-bold text-white">{mission.progress}%</span>
                    </div>
                    <div className="h-2 rounded-full bg-spacex-dark/60 overflow-hidden">
                      <motion.div
                        initial={{ width: 0 }}
                        animate={{ width: `${mission.progress}%` }}
                        transition={{ duration: 1, delay: i * 0.1 }}
                        className="h-full rounded-full bg-gradient-to-r from-spacex-accent to-spacex-thrust"
                      />
                    </div>
                  </div>

                  {/* Objectives */}
                  <div>
                    <p className="text-[10px] font-mono text-spacex-muted mb-1.5">KEY OBJECTIVES</p>
                    <div className="space-y-1">
                      {mission.objectives.slice(0, 4).map((obj, j) => (
                        <div key={j} className="flex items-start gap-1.5">
                          <CheckCircle2
                            className={`w-3 h-3 shrink-0 mt-0.5 ${
                              j < Math.floor(mission.objectives.length * mission.progress / 100)
                                ? "text-spacex-success"
                                : "text-spacex-muted/30"
                            }`}
                          />
                          <span className="text-[10px] text-spacex-text/60">{obj}</span>
                        </div>
                      ))}
                      {mission.objectives.length > 4 && (
                        <span className="text-[10px] text-spacex-accent font-mono ml-4.5">
                          +{mission.objectives.length - 4} more
                        </span>
                      )}
                    </div>
                  </div>

                  <button className="w-full flex items-center justify-center gap-1.5 py-2 rounded-lg bg-spacex-accent/10 border border-spacex-accent/20 text-[11px] font-mono text-spacex-accent hover:bg-spacex-accent/20 transition-all">
                    ENTER MISSION <ArrowUpRight className="w-3 h-3" />
                  </button>
                </div>
              </div>
            </motion.div>
          );
        })}
      </div>
    </div>
  );
}
